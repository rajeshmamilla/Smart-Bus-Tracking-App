<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Add GPS permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BusTrackV2"
        tools:targetApi="31">

        <activity
            android:name=".ScheduleResultsActivity"
            android:exported="false"
            android:label="Schedule Results"
            android:parentActivityName=".PassengerSearchActivity" />

        <activity
            android:name=".ViewScheduleActivity"
            android:exported="true"
            android:label="View Bus Schedule" />

        <activity
            android:name=".OperatorMainPageActivity"
            android:exported="false"
            android:label="Operator Dashboard" />

        <activity
            android:name=".PassengerSearchActivity"
            android:exported="true"
            android:label="Passenger Search" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OperatorLoginActivity"
            android:exported="false" />

        <activity
            android:name=".RouteScheduleActivity"
            android:exported="true"
            android:label="Route Schedule" />

        <activity
            android:name=".TrackBusActivity"
            android:exported="false"
            android:label="Track Bus"
            android:parentActivityName=".RouteScheduleActivity" />

        <activity
            android:name=".DepotLiveUpdatesActivity"
            android:exported="false"
            android:label="Depot Live Updates" />

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyBCfoSY0_G3Oy_QfQmIm5bB2zVoovS7Z8A" />

    </application>

</manifest>